    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.5.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
