:80 {
    root * /srv

    encode gzip zstd

    @static {
        path *.js *.css *.png *.jpg *.svg *.webp *.woff2
    }

    header @static {
        Cache-Control "public, max-age=31536000, immutable"
    }

    @html {
        path /
        path *.html
    }

    header @html {
        Cache-Control "public, max-age=0, must-revalidate"
    }

    try_files {path} /index.html

    file_server
}
